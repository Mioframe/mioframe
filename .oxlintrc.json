{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "oxc", "vue"],
  "options": {
    "typeAware": true
  },
  "env": {
    "browser": true,
    "node": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "eslint/no-await-in-loop": "warn",
    "eslint/no-shadow": "warn",
    "eslint/no-unneeded-ternary": "warn",
    "eslint/no-useless-rename": "error",
    "oxc/no-accumulating-spread": "warn",
    "typescript/consistent-return": "off",
    "typescript/no-unnecessary-type-arguments": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "vue/valid-define-props": "off"
  },
  "overrides": [
    {
      "files": [
        "src/app/**/*.{ts,tsx,vue}",
        "src/pages/**/*.{ts,tsx,vue}",
        "src/widgets/**/*.{ts,tsx,vue}",
        "src/features/**/*.{ts,tsx,vue}",
        "src/entities/**/*.{ts,tsx,vue}"
      ],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@shared/service/*",
                  "@shared/service/**",
                  "**/shared/service",
                  "**/shared/service/*",
                  "**/shared/service/**"
                ],
                "message": "Import from @shared/service instead of directly importing service implementation modules."
              },
              {
                "group": [
                  "@shared/ui/material/*",
                  "@shared/ui/material/**",
                  "**/shared/ui/material/*",
                  "**/shared/ui/material/**"
                ],
                "message": "Import the Material library's public entry point (@shared/ui/material) instead of a deep internal path."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/shared/ui/material/**/*.{ts,tsx,vue}"],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@feature/*",
                  "@feature/**",
                  "@entity/*",
                  "@entity/**",
                  "@widget/*",
                  "@widget/**",
                  "@page/*",
                  "@page/**"
                ],
                "message": "The Material library must not import product layers (app, pages, widgets, features, entities, processes) by alias."
              },
              {
                "regex": "^@/(?:app|pages|widgets|features|entities|processes)(?:/|$)",
                "message": "The Material library must not import product layers (app, pages, widgets, features, entities, processes) by alias."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/shared/lib/**/*.{ts,tsx,vue}"],
      "excludeFiles": ["src/shared/lib/md/**"],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@shared/ui/material",
                  "@shared/ui/material/*",
                  "@shared/ui/material/**",
                  "**/shared/ui/material",
                  "**/shared/ui/material/*",
                  "**/shared/ui/material/**"
                ],
                "message": "Generic shared/lib infrastructure must not import the Material library or gain component-family ownership."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/**/*.{ts,tsx,vue}", "tests/**/*.ts"],
      "excludeFiles": [
        "src/shared/ui/material/**",
        "src/shared/lib/**",
        "src/app/**",
        "src/pages/**",
        "src/widgets/**",
        "src/features/**",
        "src/entities/**"
      ],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@shared/ui/material/*",
                  "@shared/ui/material/**",
                  "**/shared/ui/material/*",
                  "**/shared/ui/material/**"
                ],
                "message": "Import the Material library's public entry point (@shared/ui/material) instead of a deep internal path."
              }
            ]
          }
        ]
      }
    }
  ]
}
