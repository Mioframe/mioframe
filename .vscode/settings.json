{
  "typescript.tsdk": "node_modules/typescript/lib",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "tsconfig.json": "tsconfig.*.json, env.d.ts",
    "vite.config.*": "vitest.config.*, playwright.config.*, pwa-assets.config.*",
    "package.json": "package-lock.json, pnpm*, .eslint*, eslint*, .oxlint*, oxlint*, .oxfmt*, .prettier*, prettier*"
  },
  "files.exclude": {
    "**/.stryker-tmp": true,
    "**/tmp": true,
    "**/temp": true
  },
  "files.watcherExclude": {
    "**/.stryker-tmp/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/temp/**": true,
    "**/tmp/**": true,
    "**/storybook-static/**": true,
    "**/test-results/**": true
  },
  "search.exclude": {
    "**/.stryker-tmp": true,
    "**/tmp": true,
    "**/temp": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "cSpell.words": [
    "AMRR",
    "Asyncify",
    "asynciterable",
    "asynciterablex",
    "automerge",
    "autoreset",
    "bezier",
    "bulma",
    "CFRD",
    "comlink",
    "decorationless",
    "fontawesome",
    "fortawesome",
    "fullwidth",
    "GAPI",
    "histoire",
    "jsoneditor",
    "Keyval",
    "klona",
    "longtask",
    "mdui",
    "Mioframe",
    "noction",
    "OPFS",
    "opsz",
    "oxlint",
    "oxlintrc",
    "pinia",
    "Promisable",
    "quickselect",
    "remeda",
    "typescale",
    "unhead",
    "unplugin",
    "unref",
    "vueuse",
    "vyachean",
    "wght",
    "wicg",
    "zenfs"
  ],
  "todo-tree.regex.regexCaseSensitive": false,
  "eslint.useFlatConfig": true,
  "cSpell.language": "en, ru",
  "vue.inlayHints.destructuredProps": true,
  "vue.inlayHints.inlineHandlerLeading": true,
  "vue.inlayHints.missingProps": true,
  "vue.inlayHints.vBindShorthand": true,
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "[vue]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "oxc.fixKind": "all",
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "eslint.format.enable": true,
  "eslint.lintTask.enable": true,
  "eslint.validate": ["javascript", "typescript", "vue"],
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".agents/skills/commit-message/SKILL.md"
    }
  ],
  "better-todo-tree.regex.regexCaseSensitive": false
}
