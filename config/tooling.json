{
  "localServer": {
    "host": "127.0.0.1"
  },
  "appPreview": {
    "port": 4173
  },
  "storybook": {
    "devServer": {
      "port": 6006
    },
    "visualPreview": {
      "port": 6007,
      "strictPort": true
    },
    "staticDir": "storybook-static",
    "deterministicBuildDate": "2025-01-01T00:00:00.000Z"
  },
  "playwright": {
    "webServerTimeoutMs": 240000
  },
  "verification": {
    "commandWeight": {
      "eslint": {
        "lightMaxFiles": 8,
        "mediumMaxFiles": 40
      },
      "vitest": {
        "lightMaxFiles": 8,
        "mediumMaxFiles": 24
      }
    },
    "expensiveLock": {
      "directory": ".verify/locks/expensive-command.lock",
      "heartbeatIntervalMs": 5000,
      "staleAfterMs": 30000
    },
    "verifyLock": {
      "directory": ".verify/locks/verify.lock",
      "heartbeatIntervalMs": 5000,
      "staleAfterMs": 30000
    },
    "eslint": {
      "maxLocalConcurrency": 1
    },
    "playwrightContainer": {
      "local": {
        "cpus": "2",
        "memory": "4g",
        "memorySwap": "4g",
        "pidsLimit": "384",
        "timeoutSeconds": "900",
        "workers": "1"
      },
      "githubActions": {
        "cpus": "2",
        "memory": "6g",
        "memorySwap": "8g",
        "pidsLimit": "512",
        "timeoutSeconds": "900",
        "workers": "2"
      }
    }
  }
}
