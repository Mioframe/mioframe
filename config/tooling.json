{
  "localServer": {
    "host": "127.0.0.1"
  },
  "appPreview": {
    "port": 4173
  },
  "release": {
    "basePath": "/",
    "releaseSequencePlaceholder": "__MIOFRAME_RELEASE_SEQUENCE_PENDING__",
    "artifactServer": {
      "port": 4174
    }
  },
  "pages": {
    "targetRepository": "Mioframe/mioframe.github.io",
    "tombstoneRetentionDays": 14
  },
  "storybook": {
    "devServer": {
      "port": 6006
    },
    "testPreview": {
      "port": 6007,
      "strictPort": true
    },
    "staticDir": "storybook-static",
    "deterministicBuildDate": "2025-01-01T00:00:00.000Z"
  },
  "playwright": {
    "webServerTimeoutMs": 240000
  },
  "verification": {
    "commandWeight": {
      "eslint": {
        "lightMaxFiles": 8,
        "mediumMaxFiles": 40
      },
      "vitest": {
        "lightMaxFiles": 8,
        "mediumMaxFiles": 24
      }
    },
    "machineLock": {
      "directory": ".verify/locks/machine.lock",
      "heartbeatIntervalMs": 5000,
      "staleAfterMs": 30000
    },
    "eslint": {
      "maxLocalConcurrency": 1
    },
    "playwrightContainer": {
      "cpus": "2",
      "memory": "6g",
      "memorySwap": "8g",
      "pidsLimit": "512",
      "timeoutSeconds": "900",
      "workers": "1"
    }
  }
}
