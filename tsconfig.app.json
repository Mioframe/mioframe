{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client", "@types/wicg-file-system-access"],
    "target": "es2024",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["es2024", "DOM", "DOM.Iterable", "WebWorker"],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    /* Linting */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@feature/*": ["./src/features/*"],
      "@entity/*": ["./src/entities/*"],
      "@widget/*": ["./src/widgets/*"],
      "@page/*": ["./src/pages/*"],
      "@/*": ["./src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    // "exactOptionalPropertyTypes": true // todo: turn on with refactoring
    "noImplicitOverride": true
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "exclude": ["src/**/*.cy.ts"],
  "vueCompilerOptions": {
    // "strictTemplates": true,
    "checkUnknownProps": true
  }
}
