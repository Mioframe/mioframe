{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "oxc", "vue"],
  "options": {
    "typeAware": true
  },
  "env": {
    "browser": true,
    "node": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "eslint/no-await-in-loop": "warn",
    "eslint/no-shadow": "warn",
    "eslint/no-unneeded-ternary": "warn",
    "eslint/no-useless-rename": "error",
    "oxc/no-accumulating-spread": "warn",
    "typescript/consistent-return": "off",
    "typescript/no-unnecessary-type-arguments": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "vue/valid-define-props": "off"
  },
  "overrides": [
    {
      "files": [
        "src/app/**/*.{ts,tsx,vue}",
        "src/pages/**/*.{ts,tsx,vue}",
        "src/widgets/**/*.{ts,tsx,vue}",
        "src/features/**/*.{ts,tsx,vue}",
        "src/entities/**/*.{ts,tsx,vue}"
      ],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@shared/service/*", "@shared/service/**"],
                "message": "Import from @shared/service instead of directly importing service implementation modules."
              }
            ]
          }
        ]
      }
    }
  ]
}
