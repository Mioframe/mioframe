{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/byterover/codexHooks.sh SessionStart",
            "statusMessage": "Syncing BRV memory",
            "timeout": 120000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/byterover/codexHooks.sh UserPromptSubmit",
            "statusMessage": "Checking BRV memory sync",
            "timeout": 120000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/byterover/codexHooks.sh PostToolUse",
            "statusMessage": "Refreshing BRV memory sync",
            "timeout": 120000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh scripts/byterover/codexHooks.sh Stop",
            "statusMessage": "Publishing BRV memory",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
