#!/bin/sh
set -eu

staged_paths_file="$(mktemp)"

cleanup() {
  rm -f "$staged_paths_file"
}

trap cleanup EXIT INT TERM

git diff --cached --name-only -z --diff-filter=ACMR -- \
  '*.css' \
  '*.html' \
  '*.js' \
  '*.json' \
  '*.jsx' \
  '*.md' \
  '*.mjs' \
  '*.mts' \
  '*.scss' \
  '*.ts' \
  '*.tsx' \
  '*.vue' \
  '*.yaml' \
  '*.yml' >"$staged_paths_file"

if [ ! -s "$staged_paths_file" ]; then
  exit 0
fi

xargs -0 pnpm exec oxfmt <"$staged_paths_file"
xargs -0 git add -- <"$staged_paths_file"
