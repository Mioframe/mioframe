# App runtime env
# Google OAuth client id used by the app integration layer.
VITE_GOOGLE_CLIENT_ID=

# Public Sentry DSN used by the client app in production builds.
VITE_SENTRY_DSN=

# Build-time Sentry auth token for source map upload in production/preview builds.
SENTRY_AUTH_TOKEN=

# Storybook / visual testing env
# Internal flag that marks Storybook builds so product-only Vite plugins stay disabled.
APP_STORYBOOK=

# Disables Storybook telemetry, including early boot telemetry during CLI startup.
STORYBOOK_DISABLE_TELEMETRY=

# Playwright / CI env
# CI marker used by Playwright configs to tighten retries, reporting, and server reuse behavior.
CI=

# Optional external base URL for Playwright when tests should target an already running app.
PLAYWRIGHT_EXTERNAL_BASE_URL=

# Optional preview port used by Playwright helpers when starting or probing a local preview server.
PLAYWRIGHT_PREVIEW_PORT=

# Verification / git diff env
# Optional base ref override for scripts/verify.mjs changed-file diff selection.
VERIFY_BASE=

# GitHub Actions base ref used by scripts/verify.mjs when VERIFY_BASE is not set.
GITHUB_BASE_REF=
