#!/bin/sh
set -eu

staged_paths_file="$(mktemp)"
before_diff_path="$(mktemp)"
after_diff_path="$(mktemp)"

cleanup() {
  rm -f "$staged_paths_file" "$before_diff_path" "$after_diff_path"
}

trap cleanup EXIT INT TERM

git diff --cached --name-only -z --diff-filter=ACMR -- \
  '*.css' \
  '*.html' \
  '*.js' \
  '*.json' \
  '*.jsx' \
  '*.md' \
  '*.mjs' \
  '*.mts' \
  '*.scss' \
  '*.ts' \
  '*.tsx' \
  '*.vue' \
  '*.yaml' \
  '*.yml' >"$staged_paths_file"

if [ ! -s "$staged_paths_file" ]; then
  exit 0
fi

xargs -0 git diff --binary --no-ext-diff -- <"$staged_paths_file" >"$before_diff_path"
xargs -0 pnpm exec oxfmt <"$staged_paths_file"
xargs -0 git diff --binary --no-ext-diff -- <"$staged_paths_file" >"$after_diff_path"

if ! cmp -s "$before_diff_path" "$after_diff_path"; then
  printf '%s\n' 'Pre-commit formatting updated staged files.' >&2
  printf '%s\n' 'Review the changes, stage what you want, and run commit again.' >&2
  exit 1
fi

if git diff --cached --name-only --diff-filter=ACMR \
  | rg -q '(^|/)(AGENTS\.md)$|^\.project-memory/|^scripts/project-memory/|^\.husky/pre-commit$|^package\.json$|^pnpm-lock\.yaml$|^\.github/workflows/project-memory\.yml$'; then
  pnpm memory:validate
fi
